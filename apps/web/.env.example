# Copy to .env.local and fill in your project values.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only. Used to sign Tutor Key student-session cookies.
STUDENT_SESSION_SECRET=replace-with-a-long-random-secret

# Server-only. Needed later if Tutor Key lookups are blocked by RLS.
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key
