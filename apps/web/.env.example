# Copy to .env.local and fill in the shared RISE backend values.
# RISE APP now uses the RISE Dashboard Supabase project as the source of truth.
NEXT_PUBLIC_SUPABASE_URL=https://your-dashboard-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-dashboard-supabase-publishable-or-anon-key

# Server-only. Used to sign Tutor Key student-session cookies.
STUDENT_SESSION_SECRET=replace-with-a-long-random-secret

# Server-only. Optional: only add if server-side Tutor Key table lookups need to bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key
